generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           String    @default("admin")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  address        String?
  apiKey         String?   @unique
  businessName   String?
  failedAttempts Int       @default(0)
  lastLogin      DateTime?
  lockedUntil    DateTime?
  phone          String?
  sessions       Json?
  settings       Json?
}

model Collection {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  imageUrl    String?
  order       Int                 @default(0)
  published   Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    ProductCollection[]
}

model VariationAttribute {
  id     Int                       @id @default(autoincrement())
  name   String                    @unique
  values VariationAttributeValue[]
}

model VariationAttributeValue {
  id          Int                @id @default(autoincrement())
  attributeId Int
  value       String
  colorCode   String?
  attribute   VariationAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  sku        String
  price      Float
  cost       Float    @default(0)
  stock      Int      @default(0)
  attributes Json?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SizeGuide {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  columns   Json      @default("[]")
  note      String?
  rows      Json      @default("[]")
  unit      String    @default("INCH")
  products  Product[]
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  skuPrefix   String?
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  products    Product[]
}

model Product {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  itemCode         String?             @unique
  description      String?
  price            Float
  comparePrice     Float?
  status           String              @default("draft")
  featured         Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  newArrival       Boolean             @default(false)
  bestSeller       Boolean             @default(false)
  displayOrder     Int                 @default(0)
  stock            Int                 @default(0)
  colors           Json?
  modelDetails     String?
  material         String?
  careInstructions Json?
  styleGuide       Json?
  shippingInfo     Json?
  returnInfo       Json?
  barcode          String?
  batchNumber      String?
  categoryId       String?
  costPrice        Float               @default(0)
  hasVariants      Boolean             @default(false)
  minStock         Int                 @default(5)
  productNotes     String?
  unit             String?
  variants         Json?
  weight           Float?
  sizeGuideId      String?
  colorVariants    Json?
  productType      String              @default("single")
  grnItems         GrnItem[]           @relation("GrnProduct")
  category         Category?           @relation(fields: [categoryId], references: [id])
  sizeGuide        SizeGuide?          @relation(fields: [sizeGuideId], references: [id])
  collections      ProductCollection[]
  images           ProductImage[]
  sizes            ProductSize[]
  productVariants  ProductVariant[]
  purchaseItems    PurchaseOrderItem[]
  stockRecord      Stock?
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSize {
  id        String  @id @default(cuid())
  productId String
  size      String
  stock     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

model ProductCollection {
  productId    String
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
}

model HeroSlide {
  id              String   @id @default(cuid())
  order           Int      @default(0)
  alt             String
  desktopImageUrl String
  mobileImageUrl  String
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model PageContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String?
  body      String?
  imageUrl  String?
  data      Json?
  updatedAt DateTime @updatedAt
}

model AdminCoupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String
  discountValue Float
  minOrderValue Float     @default(0)
  maxUses       Int?
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
}

model Order {
  id                  String        @id @default(cuid())
  userId              String?
  externalOrderId     String?       @unique
  ormOrderNumber      String?
  ormSynced           Boolean       @default(false)
  ormSyncError        String?
  customerName        String
  customerPhone       String
  customerEmail       String?
  shippingAddress     String
  addressLine2        String?
  city                String
  district            String
  postalCode          String?
  paymentMethod       String        @default("cod")
  paymentStatus       String        @default("pending")
  onePayTransactionId String?
  subtotal            Float         @default(0)
  shippingCost        Float         @default(0)
  discount            Float         @default(0)
  total               Float         @default(0)
  items               Json          @default("[]")
  couponCode          String?
  giftVoucherCode     String?
  giftVoucherAmount   Float?        @default(0)
  customerNote        String?
  status              String        @default("open")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  alternativePhone    String?
  assignedEmployeeId  String?
  calledAt            DateTime?
  codAmount           Float?
  codCollectedAt      DateTime?
  curfoxId            String?
  customerId          String?
  deliveryCompany     String?
  internalNotes       String?
  isPos               Boolean       @default(false)
  notes               String?
  orderNumber         String?       @unique
  posSessionId        String?
  printedAt           DateTime?
  profit              Float         @default(0)
  source              String        @default("ecommerce")
  trackingHistory     Json?
  waybillNumber       String?
  waybillSyncedAt     DateTime?
  callNotes           String?
  assignedEmployee    Employee?     @relation(fields: [assignedEmployeeId], references: [id])
  customer            Customer?     @relation(fields: [customerId], references: [id])
  posSession          PosSession?   @relation(fields: [posSessionId], references: [id])
  user                User?         @relation(fields: [userId], references: [id])
  returns             OrderReturn[]
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  phone         String?
  passwordHash  String
  emailVerified Boolean       @default(false)
  suspended     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  couponUsages  CouponUsage[]
  giftVouchers  GiftVoucher[] @relation("Purchaser")
  orders        Order[]
  otpTokens     OtpToken[]
}

model OtpToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CouponUsage {
  id         String   @id @default(cuid())
  couponCode String
  userId     String?
  sessionId  String?
  usedAt     DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@unique([couponCode, userId])
  @@unique([couponCode, sessionId])
}

model GiftVoucher {
  id              String    @id @default(cuid())
  code            String    @unique
  type            String
  amount          Float
  recipientName   String
  recipientEmail  String
  message         String?
  purchaserUserId String?
  purchaseOrderId String?
  redeemedAt      DateTime?
  redeemedOrderId String?
  createdAt       DateTime  @default(now())
  purchaser       User?     @relation("Purchaser", fields: [purchaserUserId], references: [id])
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  phone         String   @unique
  email         String?
  address       String?
  city          String?
  district      String?
  postalCode    String?
  status        String   @default("active")
  totalOrders   Int      @default(0)
  totalSpent    Float    @default(0)
  creditBalance Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  credits       Credit[] @relation("CustomerCredits")
  orders        Order[]
}

model Stock {
  id               String          @id @default(cuid())
  productId        String          @unique
  quantity         Int             @default(0)
  reservedQuantity Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements        StockMovement[]
}

model StockMovement {
  id        String   @id @default(cuid())
  stockId   String
  type      String
  quantity  Int
  reference String?
  note      String?
  createdAt DateTime @default(now())
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Employee {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  phone          String?
  passwordHash   String
  employeeId     String?
  departmentId   String?
  role           String?
  status         String      @default("active")
  joinDate       DateTime?
  salary         Float?
  address        String?
  permissions    String[]
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  department     Department? @relation(fields: [departmentId], references: [id])
  assignedOrders Order[]
}

model Supplier {
  id             String            @id @default(cuid())
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  city           String?
  district       String?
  bankAccount    String?
  bankName       String?
  totalOwed      Float             @default(0)
  totalPaid      Float             @default(0)
  status         String            @default("active")
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  grns           Grn[]             @relation("GrnSupplier")
  purchaseOrders PurchaseOrder[]
  payments       SupplierPayment[] @relation("SupplierPayments")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique
  supplierId   String?
  subtotal     Float               @default(0)
  totalAmount  Float               @default(0)
  status       String              @default("draft")
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  grns         Grn[]
  supplier     Supplier?           @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String?
  productName      String
  sku              String?
  quantity         Int
  receivedQuantity Int           @default(0)
  unitCost         Float
  total            Float
  product          Product?      @relation(fields: [productId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model PosSession {
  id          String    @id @default(cuid())
  openingCash Float     @default(0)
  closingCash Float?
  totalSales  Float     @default(0)
  totalOrders Int       @default(0)
  status      String    @default("open")
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]
}

model OrderReturn {
  id           String            @id @default(cuid())
  returnNumber String            @unique
  orderId      String
  type         String            @default("return")
  totalAmount  Float             @default(0)
  refundAmount Float             @default(0)
  reason       String?
  status       String            @default("pending")
  restockItems Boolean           @default(true)
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  order        Order             @relation(fields: [orderId], references: [id])
  items        OrderReturnItem[]
}

model OrderReturnItem {
  id          String      @id @default(cuid())
  returnId    String
  productId   String?
  productName String
  sku         String?
  quantity    Int
  unitPrice   Float
  reason      String?
  condition   String      @default("good")
  orderReturn OrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String   @id @default(cuid())
  title         String
  category      String
  amount        Float
  date          DateTime @default(now())
  paymentMethod String   @default("cash")
  reference     String?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BankAccount {
  id               String            @id @default(cuid())
  name             String
  bankName         String
  accountNo        String
  branch           String?
  accountType      String            @default("savings")
  isDefault        Boolean           @default(false)
  balance          Float             @default(0)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  fromTransfers    CashTransfer[]    @relation("FromAccount")
  toTransfers      CashTransfer[]    @relation("ToAccount")
  supplierPayments SupplierPayment[]
}

model CashTransfer {
  id            String       @id @default(cuid())
  type          String       @default("transfer")
  fromAccountId String?
  toAccountId   String?
  amount        Float
  reference     String?
  description   String?
  date          DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  fromAccount   BankAccount? @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount     BankAccount? @relation("ToAccount", fields: [toAccountId], references: [id])
}

model Grn {
  id              String         @id @default(cuid())
  grnNumber       String         @unique
  purchaseOrderId String?
  supplierId      String?
  totalAmount     Float          @default(0)
  status          String         @default("draft")
  receivedDate    DateTime       @default(now())
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplier        Supplier?      @relation("GrnSupplier", fields: [supplierId], references: [id])
  items           GrnItem[]
}

model GrnItem {
  id          String   @id @default(cuid())
  grnId       String
  productId   String?
  productName String
  sku         String?
  quantity    Int
  unitCost    Float
  total       Float
  grn         Grn      @relation(fields: [grnId], references: [id], onDelete: Cascade)
  product     Product? @relation("GrnProduct", fields: [productId], references: [id])
}

model SupplierPayment {
  id            String       @id @default(cuid())
  supplierId    String
  amount        Float
  paymentMethod String       @default("cash")
  reference     String?
  bankAccountId String?
  notes         String?
  date          DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
  supplier      Supplier     @relation("SupplierPayments", fields: [supplierId], references: [id])
}

model Credit {
  id           String   @id @default(cuid())
  customerId   String
  orderId      String?
  amount       Float
  type         String
  balanceAfter Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  customer     Customer @relation("CustomerCredits", fields: [customerId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorName String?
  actorType String?
  action    String
  model     String?
  recordId  String?
  changes   Json?
  ip        String?
  createdAt DateTime @default(now())
}

model SmsCampaign {
  id          String    @id @default(cuid())
  name        String
  message     String
  recipients  Int       @default(0)
  sent        Int       @default(0)
  failed      Int       @default(0)
  status      String    @default("draft")
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SmsContact {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  group     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
}

model CostCalFabric {
  id              String           @id @default(cuid())
  name            String
  buyingDate      String
  supplierName    String
  supplierMobile  String?
  description     String?
  costPerUnit     Float
  quantity        Float?
  unit            String?
  estimatedPieces Float?
  totalCost       Float
  images          Json?
  createdAt       DateTime         @default(now())
}

model CostCalCosting {
  id                  String   @id @default(cuid())
  productId           String   @unique
  fabricEntries       Json     @default("[]")
  pieces              Int      @default(1)
  otherCosts          Json     @default("[]")
  profitMode          String   @default("PERCENT")
  profitUnit          String   @default("PERCENT")
  profitValue         Float    @default(0)
  bnplTotal           Float    @default(0)
  bnplMerchant        Float    @default(0)
  gatewayPerc         Float    @default(0)
  vatPerc             Float    @default(0)
  deliveryTotal       Float    @default(0)
  deliveryMerchant    Float    @default(0)
  totalProductionCost Float
  netProfit           Float
  recommendedPrice    Float
  originalPrice       Float    @default(0)
  sellingPrice        Float
  status              String   @default("draft")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}


model CostCalProductionCostType {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  defaultPrice Float    @default(0)
  createdAt    DateTime @default(now())
}

model RestockRequest {
  id            String   @id @default(cuid())
  productId     String
  productName   String
  productSlug   String
  size          String
  colorHex      String?
  colorName     String?
  customerName  String
  customerEmail String
  customerPhone String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
